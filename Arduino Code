const int piezoPin = A0;
const int ledPin = 13;
const int threshold = 680;
void setup() {
pinMode(ledPin, OUTPUT);
Serial.begin(9600);
}
void loop() {
int val = analogRead(piezoPin);
Serial.println(val);
if (val > threshold) {
digitalWrite(ledPin, HIGH);
} else {
digitalWrite(ledPin, LOW);
}
delay(50);
}
